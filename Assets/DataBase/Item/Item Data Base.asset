  itemDatas:
  - ID: 1
    ExplanatoryText: "\u5927\u5C06\u4EE5\u5916\u306E\u30AB\u30FC\u30C9\u3092\u88CF\u306B\u3057\u3066\u3001\u30B7\u30E3\u30C3\u30D5\u30EB\u3059\u308B"
    Front: {fileID: -1177547440, guid: bee719e0e994eed4fb16de18defe2766, type: 3}
  - ID: 2
    ExplanatoryText: "\u9078\u3093\u3060\u81EA\u5206\u306E\u30AB\u30FC\u30C9\u306B\u7F60\u3092\u5F35\u308B"
    Front: {fileID: 1446518181, guid: bee719e0e994eed4fb16de18defe2766, type: 3}
  - ID: 3
    ExplanatoryText: "\u76F8\u624B\u306B\u8868\u306B\u3055\u305B\u308B\u30AB\u30FC\u30C9\u3092\u9078\u3070\u305B\u308B"
    Front: {fileID: 1714930792, guid: bee719e0e994eed4fb16de18defe2766, type: 3}
  - ID: 4
    ExplanatoryText: "\u30AB\u30FC\u30C9\u306E\u5F15\u3051\u308B\u679A\u6570\u3092+1\u3059\u308B"
    Front: {fileID: 1889990432, guid: bee719e0e994eed4fb16de18defe2766, type: 3}
  - ID: 5
    ExplanatoryText: "\u3053\u306E\u30BF\u30FC\u30F3\u306E\u307F\u30AB\u30FC\u30C9\u306E\u5F37\u3055\u3092\u9006\u8EE2\u3055\u305B\u308B"
    Front: {fileID: -1861723524, guid: bee719e0e994eed4fb16de18defe2766, type: 3}
  - ID: 6
    ExplanatoryText: "1\u679A\u3060\u3051\u76F8\u624B\u306E\u30AB\u30FC\u30C9\u3068\u81EA\u5206\u306E\u30AB\u30FC\u30C9\u3092\u4EA4\u63DB\u3059\u308B"
    Front: {fileID: 1455289139, guid: bee719e0e994eed4fb16de18defe2766, type: 3}
  - ID: 7
    ExplanatoryText: "\u6570\u5024\u52DD\u8CA0\u306B\u52DD\u3064\u3068\u3001\u3082\u3046\u4E00\u56DE\u653B\u6483\u3067\u304D\u308B"
    Front: {fileID: -1602235610, guid: bee719e0e994eed4fb16de18defe2766, type: 3}
  - ID: 8
    ExplanatoryText: "1\u679A\u3060\u3051\u76F8\u624B\u306E\u30A2\u30A4\u30C6\u30E0\u30AB\u30FC\u30C9\u3068\u81EA\u5206\u306E\u3092\u4EA4\u63DB\u3059\u308B"
    Front: {fileID: -1728301521, guid: bee719e0e994eed4fb16de18defe2766, type: 3}
  - ID: 9
    ExplanatoryText: "\u3053\u306E\u30BF\u30FC\u30F3\u4E2D\u3001\u30A2\u30A4\u30C6\u30E0\u306E\u4F7F\u7528\u5236\u9650\u304C\u306A\u304F\u306A\u308B"
    Front: {fileID: 1293198541, guid: bee719e0e994eed4fb16de18defe2766, type: 3}
  - ID: 10
    ExplanatoryText: "\u76F8\u624B\u306E\u30AB\u30FC\u30C9\u3092\u4E00\u679A\u9078\u3093\u3067\u3001\u30AB\u30FC\u30C9\u3092\u5F15\u304D\u76F4\u3055\u305B\u308B"
    Front: {fileID: -1001251493, guid: bee719e0e994eed4fb16de18defe2766, type: 3}
